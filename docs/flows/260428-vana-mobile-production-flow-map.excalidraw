    },
    {
      "id": "d2-phase-1-text",
      "type": "text",
      "x": 25,
      "y": 1491,
      "width": 310,
      "height": 190,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 510006,
      "version": 1,
      "versionNonce": 610006,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "1. Desktop signup\n\nUser opens DataConnect.\nPrivy creates wallet W.\nUser signs master key string once.\nBundled PS creates its own keypair.\n\nUI meaning: Setting up your private data space.",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Desktop signup\n\nUser opens DataConnect.\nPrivy creates wallet W.\nUser signs master key string once.\nBundled PS creates its own keypair.\n\nUI meaning: Setting up your private data space.",
      "lineHeight": 1.25,
      "baseline": 186
    },
    {
      "id": "d2-phase-2",
      "type": "rectangle",
      "x": 400,
      "y": 1463,
      "width": 360,
