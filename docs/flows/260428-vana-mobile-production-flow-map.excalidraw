      "versionNonce": 610014,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "5. User-visible grant\n\nBuilder asks for Instagram posts.\nUser approves with device confirmation.\naccount.vana.org signs allowlisted grant.\nBuilder posts signed intent to DP RPC.\n\nUI meaning: App wants this data. Allow?",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "5. User-visible grant\n\nBuilder asks for Instagram posts.\nUser approves with device confirmation.\naccount.vana.org signs allowlisted grant.\nBuilder posts signed intent to DP RPC.\n\nUI meaning: App wants this data. Allow?",
      "lineHeight": 1.25,
      "baseline": 186
    },
    {
