      "roundness": null,
      "seed": 510012,
      "version": 1,
      "versionNonce": 610012,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "4. Mobile Vana auth\n\nBuilder/mobile app starts Connect with Vana.\nUser authenticates via account.vana.org.\nAcct validates provider proof and mints Vana JWT with sub = wallet W.\n\nUI meaning: Sign in to Vana.",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "4. Mobile Vana auth\n\nBuilder/mobile app starts Connect with Vana.\nUser authenticates via account.vana.org.\nAcct validates provider proof and mints Vana JWT with sub = wallet W.\n\nUI meaning: Sign in to Vana.",
      "lineHeight": 1.25,
      "baseline": 186
    },
    {
