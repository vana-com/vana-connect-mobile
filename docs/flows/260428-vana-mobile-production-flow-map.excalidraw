      "isDeleted": false,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false
    },
    {
      "id": "d2-phase-2-text",
      "type": "text",
      "x": 425,
      "y": 1491,
      "width": 310,
      "height": 190,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 510008,
      "version": 1,
      "versionNonce": 610008,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "2. Register servers\n\nDataConnect probes BPS + HPS.\naccount.vana.org silent-signs allowlisted server registration.\nDP RPC registers/trusts both PSes on-chain.\n\nUI meaning: Your data can stay available.",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "2. Register servers\n\nDataConnect probes BPS + HPS.\naccount.vana.org silent-signs allowlisted server registration.\nDP RPC registers/trusts both PSes on-chain.\n\nUI meaning: Your data can stay available.",
      "lineHeight": 1.25,
      "baseline": 186
    },
    {
      "id": "d2-phase-3",
      "type": "rectangle",
      "x": 800,
      "y": 1463,
      "width": 420,
      "height": 260,
      "angle": 0,
      "strokeColor": "#15803d",
      "backgroundColor": "#dcfce7",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
