      "locked": false
    },
    {
      "id": "d2-phase-6-text",
      "type": "text",
      "x": 2085,
      "y": 1491,
      "width": 370,
      "height": 190,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
