      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Actors: User | DataConnect desktop | Privy + account.vana.org | Bundled PS | Hosted PS | User cloud storage | DP RPC gateway | Vana L1 | Builder/mobile app",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Actors: User | DataConnect desktop | Privy + account.vana.org | Bundled PS | Hosted PS | User cloud storage | DP RPC gateway | Vana L1 | Builder/mobile app",
      "lineHeight": 1.25,
