      "versionNonce": 610009,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false
    },
    {
      "id": "d2-phase-3-text",
      "type": "text",
      "x": 825,
      "y": 1491,
      "width": 370,
      "height": 190,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 510010,
      "version": 1,
      "versionNonce": 610010,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "3. Scrape + escrow\n\nUser connects Instagram in DataConnect.\nConnector extracts data.\nBPS encrypts each file with random K.\nCloud stores ciphertext.\nBPS escrows K to BPS + HPS via DP RPC.\n\nUI meaning: connected data is private and portable.",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "3. Scrape + escrow\n\nUser connects Instagram in DataConnect.\nConnector extracts data.\nBPS encrypts each file with random K.\nCloud stores ciphertext.\nBPS escrows K to BPS + HPS via DP RPC.\n\nUI meaning: connected data is private and portable.",
      "lineHeight": 1.25,
      "baseline": 186
    },
    {
      "id": "d2-phase-4",
      "type": "rectangle",
