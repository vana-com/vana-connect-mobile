    },
    {
      "id": "d2-phase-4-text",
      "type": "text",
      "x": 1285,
      "y": 1491,
      "width": 310,
      "height": 190,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
